# AIDEPOR Environment Variables
# Copy this file to .env and fill in your values
# API keys are stored locally on-device — these are only for server-side features

# OpenRouter API Key (recommended — gives access to 200+ models)
OPENROUTER_API_KEY=sk-or-your-key-here

# Optional: individual provider keys (can also be set in the app UI)
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_AI_API_KEY=AIza-your-google-key
